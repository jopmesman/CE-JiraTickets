{
  "name": "JiraTickets",
  "version": "2.0",
  "description": "Type in a jira ticket and gogogo",
  "permissions": ["storage", "tabs"],
  "options_page": "options.html",
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "48": "icons/48.png",
      "128": "icons/128.png"
    }
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+J",
        "mac": "Command+J"
      },
      "description": "Open Jira ticket popup"
    }
  },
  "manifest_version": 3,
  "icons": {
    "48": "icons/48.png",
    "128": "icons/128.png"
  }
}